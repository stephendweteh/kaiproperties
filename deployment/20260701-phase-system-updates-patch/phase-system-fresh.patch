+echo ""
+
+# Validate we're in the right place
+if [ ! -f "$REPO_ROOT/artisan" ]; then
+  echo "ERROR: artisan file not found in current directory!"
+  echo ""
+  echo "Please navigate to your project root first:"
+  echo "  cd /path/to/kai-maintenance-system"
